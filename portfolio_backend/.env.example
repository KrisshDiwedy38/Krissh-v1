SECRET_KEY=your-secret-key-goes-here-keep-it-safe
DEBUG=True

# Supabase PostgreSQL Database Credentials
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=aws-0-eu-central-1.pooler.supabase.com # Replace with your Supabase host
DB_PORT=6543 # Usually 6543 for connection pooling or 5432 for direct

# Allowed Hosts & CORS
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
